use crate::utils::Timer;
use petgraph::graph::{NodeIndex, UnGraph};
use plotters::prelude::*;
use rand::prelude::*;
use std::{
    fs::File,
    io::{self, Write},
};

#[derive(Debug, Clone, Copy, PartialEq)]
pub enum NodeType {
    Magic,
    Bus,
    Data,
    Ancilla,
    Estabilizer,
}

impl NodeType {
    fn from_char(c: char) -> Option<Self> {
        match c {
            'm' => Some(NodeType::Magic),
            'b' => Some(NodeType::Bus),
            'd' => Some(NodeType::Data),
            'a' => Some(NodeType::Ancilla),
            'e' => Some(NodeType::Estabilizer),
            _ => None,
        }
    }

    fn color(&self) -> RGBColor {
        match self {
            NodeType::Magic => RGBColor(0xFF, 0xBB, 0x99),
            NodeType::Bus => RGBColor(0xAA, 0xAA, 0xAA),
            NodeType::Data => RGBColor(0x99, 0x99, 0xFF),
            NodeType::Ancilla => RGBColor(0xFF, 0x88, 0xAA),
            NodeType::Estabilizer => RGBColor(0x99, 0xCC, 0x99),
        }
    }
}

#[derive(Debug)]
pub struct Node {
    node_type: NodeType,
    label: String,
    pos: (f64, f64),
    busy_count: Option<i32>,
}

pub struct TopoGraph {
    graph: UnGraph<Node, ()>,
    node_grid: Vec<Vec<Option<String>>>,
    num_cols: usize,
    num_rows: usize,
    num_data_qubits: usize,
    num_bus_qubits: usize,
    num_magic_qubits: usize,
    num_ancilla_qubits: usize,
    num_estabilizer_qubits: usize,
    num_qubits: usize,
    rng: StdRng,
}

// Helper functions
pub fn is_magic_node(node: &str) -> bool {
    node.starts_with('m')
}

pub fn is_bus_node(node: &str) -> bool {
    node.starts_with('b')
}

pub fn is_data_node(node: &str) -> bool {
    node.starts_with('d')
}

pub fn is_ancilla_node(node: &str) -> bool {
    node.starts_with('a')
}

pub fn is_estabilizer_node(node: &str) -> bool {
    node.starts_with('e')
}

impl TopoGraph {
    pub fn new(rng: StdRng) -> Self {
        TopoGraph {
            graph: UnGraph::new_undirected(),
            node_grid: Vec::new(),
            num_cols: 0,
            num_rows: 0,
            num_data_qubits: 0,
            num_bus_qubits: 0,
            num_magic_qubits: 0,
            num_ancilla_qubits: 0,
            num_estabilizer_qubits: 0,
            num_qubits: 0,
            rng,
        }
    }

    pub fn set_topo(&mut self, min_num_qubits: usize) {
        let _timer = Timer::new("set_topo");

        let sq_dim = (min_num_qubits as f64).sqrt().floor() as usize;
        let patch_rows = sq_dim / 2 + sq_dim % 2;
        let bus_rows = patch_rows + 1;

        let qubits_per_col = 2 * patch_rows;
        let num_data_cols = ((min_num_qubits as f64) / (qubits_per_col as f64)).ceil() as usize;

        self.num_cols = 2 * num_data_cols + 3;
        self.num_rows = 2 + 2 * patch_rows + bus_rows;

        // Initialize node grid
        self.node_grid = vec![vec![None; self.num_rows]; self.num_cols];

        if self.num_cols > 0 && self.num_rows > 0 {
            println!("Layout dimensions: {} {}", self.num_cols, self.num_rows);
            self.gen_topo();
            self.update_statistics();
        }
    }

    fn add_node(&mut self, label: &str, x: f64, y: f64, node_type: NodeType) -> String {
        let node = Node {
            node_type,
            label: label.to_string(),
            pos: (x, y),
            busy_count: if node_type == NodeType::Magic {
                Some(0)
            } else {
                None
            },
        };
        self.graph.add_node(node);
        format!("{}{}-{}", label, math.ceil(x), math.ceil(y))
    }

    fn add_border_row(&mut self, row: usize) {
        // Add corner bus nodes
        self.node_grid[0][row] = Some(self.add_node("b", 0.0, row as f64, NodeType::Bus));
        self.node_grid[self.num_cols - 1][row] =
            Some(self.add_node("b", (self.num_cols - 1) as f64, row as f64, NodeType::Bus));

        // Add alternating magic/ancilla nodes
        for col in 1..self.num_cols - 1 {
            let node_type = if col % 2 == 1 {
                NodeType::Magic
            } else if col % 4 == 0 {
                NodeType::Ancilla
            } else {
                NodeType::Magic
            };

            let label = match node_type {
                NodeType::Magic => "m",
                NodeType::Ancilla => "a",
                _ => "b",
            };

            self.node_grid[col][row] =
                Some(self.add_node(label, col as f64, row as f64, node_type));
        }
    }

    fn add_border_column(&mut self, col: usize) {
        for row in 1..self.num_rows - 1 {
            self.node_grid[col][row] =
                Some(self.add_node("m", col as f64, row as f64, NodeType::Magic));
        }
    }

    fn add_data_qubit(&mut self, qi: usize, col: usize, row: usize, is_x: bool) {
        let q = if is_x { qi / 2 } else { qi / 2 - 1 };
        let op = if is_x { 'X' } else { 'Z' };

        // Add left data node
        self.add_node(
            &format!("d{}{}", q, op),
            col as f64 - 0.25,
            row as f64,
            NodeType::Data,
        );

        // Add right data node
        self.add_node(
            &format!("d{}{}", q + 1, op),
            col as f64 + 0.25,
            row as f64,
            NodeType::Data,
        );

        let combined_label = format!("d{}/{}{}", q, q + 1, op);
        self.node_grid[col][row] = Some(combined_label);
        self.num_data_qubits += 2;
    }

    fn gen_topo(&mut self) {
        // Add top border row
        self.add_border_row(0);

        // Add border columns
        self.add_border_column(0);

        // Add center nodes
        let mut qi = 0;
        for col in 1..self.num_cols - 1 {
            if col % 2 == 0 {
                // Data column
                for row in 1..self.num_rows - 1 {
                    if row % 3 + 1 == 2 {
                        if row % 6 + 1 == 5 && row != self.num_rows - 2 && col % 4 == 0 {
                            self.node_grid[col][row] = Some(self.add_node(
                                "e",
                                col as f64,
                                row as f64,
                                NodeType::Estabilizer,
                            ));
                            self.num_estabilizer_qubits += 1;
                        } else {
                            self.node_grid[col][row] =
                                Some(self.add_node("b", col as f64, row as f64, NodeType::Bus));
                            self.num_bus_qubits += 1;
                        }
                    } else {
                        self.add_data_qubit(qi, col, row, row % 3 + 1 == 3);
                        qi += 2;
                    }
                }
            } else {
                // Bus column
                for row in 1..self.num_rows - 1 {
                    self.node_grid[col][row] =
                        Some(self.add_node("b", col as f64, row as f64, NodeType::Bus));
                    self.num_bus_qubits += 1;
                }
            }
        }

        // Add right edge column and bottom row
        self.add_border_column(self.num_cols - 1);
        self.add_border_row(self.num_rows - 1);

        self.set_edges();
        println!(
            "Generated topology with dimensions: {} {}",
            self.num_cols, self.num_rows
        );
    }

    fn set_edges(&mut self) {
        let mut edges_to_add = Vec::new();

        // Collect edges first
        for row in 0..self.num_rows {
            for col in 0..self.num_cols {
                if let Some(node_idx) = self.node_grid[col][row] {
                    // Add horizontal edges
                    if col > 0 {
                        if let Some(left_idx) = self.node_grid[col - 1][row] {
                            if !self.is_magic_pair(node_idx, left_idx) {
                                edges_to_add.push((node_idx, left_idx));
                            }
                        }
                    }

                    // Add vertical edges
                    if row > 0 {
                        if let Some(up_idx) = self.node_grid[col][row - 1] {
                            let node = &self.graph[node_idx];
                            let up_node = &self.graph[up_idx];
                            if !self.is_data_node(&node.label) && !self.is_data_node(&up_node.label)
                            {
                                edges_to_add.push((node_idx, up_idx));
                            }
                        }
                    }
                }
            }
        }

        // Add all edges
        for (n1, n2) in edges_to_add {
            self.graph.add_edge(n1, n2, ());
        }
    }

    fn is_magic_pair(&self, idx1: NodeIndex, idx2: NodeIndex) -> bool {
        let node1 = &self.graph[idx1];
        let node2 = &self.graph[idx2];
        node1.node_type == NodeType::Magic && node2.node_type == NodeType::Magic
    }

    fn update_statistics(&mut self) {
        // Count node types
        let mut data_count = 0;
        let mut magic_count = 0;
        let mut bus_count = 0;
        let mut ancilla_count = 0;
        let mut estabilizer_count = 0;

        for node in self.graph.node_indices() {
            match self.graph[node].node_type {
                NodeType::Data => data_count += 1,
                NodeType::Magic => magic_count += 1,
                NodeType::Bus => bus_count += 1,
                NodeType::Ancilla => ancilla_count += 1,
                NodeType::Estabilizer => estabilizer_count += 1,
            }
        }

        // Data nodes come in pairs
        self.num_data_qubits = data_count / 2;
        self.num_magic_qubits = magic_count;
        self.num_bus_qubits = bus_count;
        self.num_ancilla_qubits = ancilla_count;
        self.num_estabilizer_qubits = estabilizer_count;

        self.num_qubits = self.num_data_qubits
            + self.num_bus_qubits
            + self.num_magic_qubits
            + self.num_ancilla_qubits
            + self.num_estabilizer_qubits;

        let total = self.num_qubits as f64;
        println!("Number of qubits:");
        println!(
            "  data:         {} ({:.3})",
            self.num_data_qubits,
            self.num_data_qubits as f64 / total
        );
        println!(
            "  bus:          {} ({:.3})",
            self.num_bus_qubits,
            self.num_bus_qubits as f64 / total
        );
        println!(
            "  magic:        {} ({:.3})",
            self.num_magic_qubits,
            self.num_magic_qubits as f64 / total
        );
        println!(
            "  ancilla:      {} ({:.3})",
            self.num_ancilla_qubits,
            self.num_ancilla_qubits as f64 / total
        );
        println!(
            "  e-stabilizer: {} ({:.3})",
            self.num_estabilizer_qubits,
            self.num_estabilizer_qubits as f64 / total
        );
        println!("  total:        {}", self.num_qubits);
    }

    pub fn plot(&self, fname: &str) -> Result<(), Box<dyn std::error::Error>> {
        let _timer = Timer::new("plot");

        // Create output file
        let png_name = format!("{}.png", fname);

        let root = BitMapBackend::new(&png_name, (1800, 900)).into_drawing_area();
        root.fill(&WHITE)?;

        // Calculate plot dimensions
        let margin = 50;
        let mut chart = ChartBuilder::on(&root)
            .margin(margin)
            .set_label_area_size(LabelAreaPosition::Left, 60)
            .set_label_area_size(LabelAreaPosition::Bottom, 40)
            .caption("Topology Graph", ("sans-serif", 20))
            .build_cartesian_2d(-1f32..self.num_cols as f32, -1f32..self.num_rows as f32)?;

        // Configure chart
        chart.configure_mesh().disable_mesh().draw()?;

        // Draw edges
        for edge in self.graph.edge_indices() {
            let (n1, n2) = self.graph.edge_endpoints(edge).unwrap();
            let node1 = &self.graph[n1];
            let node2 = &self.graph[n2];

            chart.draw_series(LineSeries::new(
                vec![
                    (node1.pos.0 as f32, node1.pos.1 as f32),
                    (node2.pos.0 as f32, node2.pos.1 as f32),
                ],
                &BLACK.mix(0.5),
            ))?;
        }

        // Draw nodes
        for node_idx in self.graph.node_indices() {
            let node = &self.graph[node_idx];
            let (x, y) = node.pos;

            // Draw node circle
            chart.draw_series(std::iter::once(Circle::new(
                (x as f32, y as f32),
                5,
                node.node_type.color().filled(),
            )))?;

            // Draw node label
            chart.draw_series(std::iter::once(Text::new(
                node.label.clone(),
                (x as f32, y as f32 - 0.2),
                ("sans-serif", 15).into_font(),
            )))?;
        }

        // Save SVG version
        let svg_name = format!("{}.svg", fname);
        let svg_root = SVGBackend::new(&svg_name, (1800, 900)).into_drawing_area();

        svg_root.present()?;

        Ok(())
    }

    pub fn save(&self, fname: &str) -> io::Result<()> {
        let mut file = File::create(fname)?;

        for row in 0..self.num_rows {
            for col in 0..self.num_cols {
                if let Some(node_idx) = self.node_grid[col][row] {
                    let node = &self.graph[node_idx];
                    write!(file, "{:8} ", node.label)?;
                } else {
                    write!(file, "{:8} ", ".")?;
                }
            }
            writeln!(file)?;
        }

        Ok(())
    }

    pub fn load(&mut self, fname: &str) -> io::Result<()> {
        let contents = std::fs::read_to_string(fname)?;
        let lines: Vec<_> = contents.lines().collect();

        self.num_rows = lines.len();
        self.num_cols = lines[0].split_whitespace().count();
        self.node_grid = vec![vec![None; self.num_rows]; self.num_cols];

        for (row, line) in lines.iter().enumerate() {
            for (col, label) in line.split_whitespace().enumerate() {
                if label != "." {
                    let node_type = match label.chars().next().unwrap() {
                        'm' => NodeType::Magic,
                        'b' => NodeType::Bus,
                        'd' => NodeType::Data,
                        'a' => NodeType::Ancilla,
                        'e' => NodeType::Estabilizer,
                        _ => continue,
                    };

                    let node_idx = self.add_node(label, col as f64, row as f64, node_type);
                    self.node_grid[col][row] = Some(node_idx);
                }
            }
        }

        self.set_edges();
        Ok(())
    }

    fn is_data_node(&self, label: &str) -> bool {
        label.starts_with('d')
    }
}
